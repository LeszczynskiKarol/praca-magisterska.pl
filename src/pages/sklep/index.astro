---
// src/pages/sklep/index.astro
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import Layout from "../../layouts/Layout.astro";

const kierunkowe = [
  {
    id: "psychologia",
    kierunek: "Psychologia",
    icon: "🧠",
    subtitle: "Od konstruktu do obrony",
    desc: "Operacjonalizacja, moc statystyczna, narzędzia w polskich adaptacjach, standard APA.",
    href: "/sklep/jak-napisac-prace-magisterska-z-psychologii/",
    gradient: "from-indigo-900 to-purple-800",
    border: "hover:border-purple-400",
    badge: "Wydanie II · 2026",
  },
  {
    id: "pielegniarstwo",
    kierunek: "Pielęgniarstwo",
    icon: "🩺",
    subtitle: "Od problemu klinicznego do obrony",
    desc: "Badania na oddziale, zgody i komisja bioetyczna, skale standaryzowane, styl Vancouver.",
    href: "/sklep/jak-napisac-prace-magisterska-z-pielegniarstwa/",
    gradient: "from-teal-900 to-emerald-800",
    border: "hover:border-teal-400",
    badge: "Nowość 2026",
  },
  {
    id: "pedagogika",
    kierunek: "Pedagogika",
    icon: "🧑‍🏫",
    subtitle: "Od problemu wychowawczego do obrony",
    desc: "Sondaż i eksperyment, badania w szkole, narzędzia badawcze, statystyka bez paniki.",
    href: "/sklep/jak-napisac-prace-magisterska-z-pedagogiki/",
    gradient: "from-rose-900 to-red-800",
    border: "hover:border-rose-400",
    badge: "Nowość 2026",
  },
  {
    id: "prawo",
    kierunek: "Prawo",
    icon: "⚖️",
    subtitle: "Od tezy do obrony",
    desc: "Metoda dogmatyczna, wykładnia, orzecznictwo, przypisy prawnicze i trzy wykazy.",
    href: "/sklep/jak-napisac-prace-magisterska-z-prawa/",
    gradient: "from-slate-900 to-blue-900",
    border: "hover:border-blue-400",
    badge: "Nowość 2026",
  },
  {
    id: "administracja",
    kierunek: "Administracja",
    icon: "🏛️",
    subtitle: "Od problemu do obrony",
    desc: "Prawo administracyjne, orzecznictwo WSA i NSA, rozdział ustrojowy, badanie praktyki urzędów.",
    href: "/sklep/jak-napisac-prace-magisterska-z-administracji/",
    gradient: "from-slate-800 to-gray-700",
    border: "hover:border-slate-400",
    badge: "Nowość 2026",
  },
  {
    id: "logistyka",
    kierunek: "Logistyka",
    icon: "🚚",
    subtitle: "Od procesu do obrony",
    desc: "Analiza procesów w firmie, dane i poufność, mapowanie, wskaźniki KPI, usprawnienia z rachunkiem.",
    href: "/sklep/jak-napisac-prace-magisterska-z-logistyki/",
    gradient: "from-orange-900 to-amber-800",
    border: "hover:border-orange-400",
    badge: "Nowość 2026",
  },
  {
    id: "informatyka",
    kierunek: "Informatyka",
    icon: "💻",
    subtitle: "Od koncepcji do obrony",
    desc: "Wymagania, projekt systemu, implementacja, testy oraz eksperymenty i benchmarki z rygorem.",
    href: "/sklep/jak-napisac-prace-magisterska-z-informatyki/",
    gradient: "from-cyan-900 to-slate-800",
    border: "hover:border-cyan-400",
    badge: "Nowość 2026",
  },
];

const products = [
  {
    id: "magisterska",
    title: "Jak napisać pracę magisterską",
    subtitle: "Zaawansowany poradnik dla magistrantów",
    price: 39,
    pages: 250,
    chapters: 22,
    icon: "📗",
    color: "accent",
    href: "/sklep/praca-magisterska-ebook",
    badge: "Bestseller",
    cta: "Zobacz szczegóły →",
    external: false,
    features: [
      "Kompletny proces pisania pracy magisterskiej",
      "Zaawansowana metodologia",
      "Badania ilościowe i jakościowe",
      "Analiza statystyczna",
      "Praca z promotorem na poziomie mgr",
      "Recenzja i poprawki",
      "Obrona magisterska",
    ],
  },
  {
    id: "licencjacka",
    title: "Piszesz pracę licencjacką?",
    subtitle: "Osobny poradnik czeka na licencjackie.pl",
    price: 39,
    pages: 250,
    chapters: 18,
    icon: "📘",
    color: "primary",
    href: "https://www.licencjackie.pl/ebook/",
    badge: "Na licencjackie.pl",
    cta: "Zobacz na licencjackie.pl →",
    external: true,
    features: [
      "Wybór i zawężanie tematu",
      "Przegląd literatury krok po kroku",
      "Struktura pracy licencjackiej",
      "Metodologia badań",
      "Cytaty, przypisy, bibliografia",
      "Formatowanie w Word",
      "Przygotowanie do obrony",
    ],
  },
];
---

<Layout
  title="Sklep: ebooki o pisaniu pracy magisterskiej — poradnik ogólny i przewodniki kierunkowe | Praca-Magisterska.pl"
  description="Kompletny poradnik pisania pracy magisterskiej (250 stron, 39 zł) oraz przewodniki kierunkowe PDF + EPUB za 49 zł: psychologia, pielęgniarstwo, pedagogika, prawo. Dostęp natychmiast po zakupie."
>
  <Navbar />

  <main class="min-h-screen">
    
    <!-- ============ HERO ============ -->
    <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <div class="inline-block bg-accent/20 text-accent px-4 py-1 rounded-full text-sm font-medium mb-6">
          📚 Ebooki • Poradniki pisania prac dyplomowych
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white leading-tight">
          Jak napisać pracę dyplomową?
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-8 max-w-3xl mx-auto">
          Uniwersalne poradniki od A do Z i przewodniki kierunkowe pisane pod konkretny kierunek studiów.
          <strong class="text-white">Bez stresu. Bez błądzenia po omacku.</strong>
        </p>
        
        <div class="flex flex-wrap justify-center gap-4 text-slate-400 text-sm mb-12">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Sprawdzone przez tysiące studentów
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Aktualizowane na 2026
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Dostęp natychmiast
          </span>
        </div>
        
        <!-- Scroll indicator -->
        <a href="#produkty" class="inline-flex flex-col items-center text-slate-400 hover:text-white transition-colors">
          <span class="text-sm mb-2">Zobacz poradniki</span>
          <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </section>


    <!-- ============ PRODUKTY ============ -->
    <section id="produkty" class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">Wybierz swój poradnik</h2>
        <p class="text-center text-slate-600 mb-12">Który typ pracy piszesz?</p>
        
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {products.map((product) => (
            <div class={`relative bg-white rounded-2xl border-2 ${product.color === 'accent' ? 'border-accent' : 'border-primary-500'} shadow-xl overflow-hidden hover:shadow-2xl transition-shadow`}>
              <!-- Badge -->
              <div class={`absolute top-4 right-4 ${product.color === 'accent' ? 'bg-accent' : 'bg-primary-600'} text-white text-xs font-bold px-3 py-1 rounded-full`}>
                {product.badge}
              </div>
              
              <div class="p-8">
                <!-- Icon & Title -->
                <div class="text-center mb-6">
                  <span class="text-6xl mb-4 block">{product.icon}</span>
                  <h3 class="text-2xl font-bold text-slate-900 mb-2">{product.title}</h3>
                  <p class="text-slate-600">{product.subtitle}</p>
                </div>
                
                <!-- Stats -->
                <div class="flex justify-center gap-6 mb-6 text-sm">
                  <div class="text-center">
                    <div class="text-2xl font-bold text-slate-900">{product.pages}</div>
                    <div class="text-slate-500">stron</div>
                  </div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-slate-900">{product.chapters}</div>
                    <div class="text-slate-500">rozdziałów</div>
                  </div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-slate-900">PDF</div>
                    <div class="text-slate-500">format</div>
                  </div>
                </div>
                
                <!-- Features -->
                <ul class="space-y-2 mb-8">
                  {product.features.map((feature) => (
                    <li class="flex items-start gap-2 text-slate-700">
                      <svg class={`w-5 h-5 ${product.color === 'accent' ? 'text-accent' : 'text-primary-600'} mt-0.5 flex-shrink-0`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                
                <!-- Price & CTA -->
                <div class="text-center">
                  <div class="mb-4">                    
                    <span class="text-4xl font-bold text-slate-900 ml-2">{product.price} zł</span>
                  </div>
                  
                  <a
                    href={product.href}
                    target={product.external ? '_blank' : undefined}
                    rel={product.external ? 'noopener' : undefined}
                    class={`block w-full py-4 px-6 rounded-xl font-bold text-white text-lg transition-all hover:scale-105 ${product.color === 'accent' ? 'bg-accent hover:bg-green-600' : 'bg-primary-600 hover:bg-primary-700'}`}
                  >
                    {product.cta}
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Pakiet info -->
        <div class="mt-12 text-center">
          <div class="inline-block bg-amber-50 border border-amber-200 rounded-xl px-6 py-4">
            <p class="text-amber-800">
              <strong>💡 Wskazówka:</strong> Jeśli planujesz też pisać magisterską — kup od razu poradnik magisterski.
              Zawiera wszystko z wersji licencjackiej + zaawansowane tematy.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ============ PRZEWODNIKI KIERUNKOWE ============ -->
    <section id="kierunkowe" class="py-16 bg-slate-900">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
          <div class="inline-block bg-accent/20 text-accent px-4 py-1 rounded-full text-sm font-medium mb-4">
            ✨ Nowa seria 2026
          </div>
          <h2 class="text-3xl font-bold text-white mb-4">Przewodniki kierunkowe — 49 zł</h2>
          <p class="text-slate-300 max-w-2xl mx-auto">
            Piszesz magisterkę z konkretnego kierunku? Te przewodniki mówią językiem Twojej dziedziny:
            jej metod, narzędzi i wymagań recenzentów. 16 rozdziałów, format <strong class="text-white">PDF + EPUB</strong>.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {kierunkowe.map((k) => (
            <a
              href={k.href}
              class={`group flex flex-col rounded-2xl overflow-hidden border-2 border-transparent ${k.border} bg-slate-800 transition-all hover:scale-105 hover:shadow-2xl`}
            >
              <div class={`bg-gradient-to-br ${k.gradient} p-6 text-center`}>
                <span class="text-5xl block mb-3">{k.icon}</span>
                <h3 class="text-xl font-bold text-white">{k.kierunek}</h3>
                <p class="text-sm text-white/70 mt-1">{k.subtitle}</p>
              </div>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex flex-wrap gap-2 mb-3">
                  <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full">PDF + EPUB</span>
                  <span class="bg-slate-700 text-slate-300 text-xs px-2 py-0.5 rounded-full">16 rozdziałów</span>
                  <span class="bg-accent/20 text-accent text-xs px-2 py-0.5 rounded-full">{k.badge}</span>
                </div>
                <p class="text-slate-400 text-sm flex-1">{k.desc}</p>
                <div class="mt-4 pt-4 border-t border-slate-700 flex items-center justify-between">
                  <span class="text-2xl font-bold text-white">49 zł</span>
                  <span class="text-accent font-medium text-sm group-hover:translate-x-1 transition-transform">Zobacz →</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <p class="text-center text-slate-400 text-sm mt-8">
          Piszesz pracę licencjacką z pielęgniarstwa? Przewodnik znajdziesz na
          <a href="https://www.licencjackie.pl/ebook-pielegniarstwo/" class="text-accent hover:underline" rel="noopener">licencjackie.pl</a>.
        </p>
      </div>
    </section>


    <!-- ============ DLACZEGO NASZE EBOOKI ============ -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">Dlaczego nasze poradniki?</h2>
        <p class="text-center text-slate-600 mb-12">W internecie jest dużo darmowych materiałów. Czym te się różnią?</p>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">📋</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Wszystko w jednym miejscu</h3>
            <p class="text-slate-600 text-sm">Zamiast szukać informacji po 50 stronach — masz kompletny poradnik od A do Z. Oszczędzasz 20-30 godzin.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">🎯</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Konkrety, nie teoria</h3>
            <p class="text-slate-600 text-sm">Zero akademickiego bełkotu. Praktyczne instrukcje, przykłady, szablony — to co naprawdę potrzebujesz.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">✅</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Sprawdzone przez studentów</h3>
            <p class="text-slate-600 text-sm">Tysiące studentów już skorzystało z naszych poradników. Wiemy, co działa, a co nie.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">🔄</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Aktualne wydania 2026</h3>
            <p class="text-slate-600 text-sm">Żadnych przestarzałych informacji. Poradniki są regularnie aktualizowane zgodnie z aktualnymi wymogami.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">📄</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Szablony w zestawie</h3>
            <p class="text-slate-600 text-sm">Strona tytułowa, spis treści, wzory zdań, checklisty — gotowe do użycia od razu.</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <span class="text-2xl">⚡</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Dostęp w 30 sekund</h3>
            <p class="text-slate-600 text-sm">Płacisz — dostajesz link na email. PDF otworzysz na każdym urządzeniu. Zacznij pisać od razu.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ============ CO ZNAJDZIESZ W PORADNIKACH ============ -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">Co znajdziesz w poradnikach?</h2>
        <p class="text-center text-slate-600 mb-12">Oba ebooki prowadzą Cię przez cały proces pisania pracy dyplomowej</p>
        
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Kolumna 1 -->
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
              <span class="w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span>
              Zanim zaczniesz pisać
            </h3>
            <div class="space-y-4 ml-10">
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Wybór tematu</h4>
                <p class="text-sm text-slate-600">Skąd brać pomysły? Jak zawęzić temat? Jak rozmawiać z promotorem? Technika 5 poziomów zawężania z przykładami.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Przegląd literatury</h4>
                <p class="text-sm text-slate-600">Gdzie szukać źródeł (15+ baz danych z linkami). Metoda śnieżnej kuli. Jak odróżnić dobre źródło od śmieciowego.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Plan i harmonogram</h4>
                <p class="text-sm text-slate-600">Struktura pracy — szablon. Realny harmonogram od tematu do obrony. Techniki zarządzania czasem.</p>
              </div>
            </div>
            
            <h3 class="text-xl font-bold text-slate-900 mb-6 mt-10 flex items-center gap-2">
              <span class="w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span>
              Struktura pracy
            </h3>
            <div class="space-y-4 ml-10">
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Wstęp</h4>
                <p class="text-sm text-slate-600">Co MUSI być we wstępie (checklist). Cel, pytania badawcze, hipotezy. Kiedy pisać wstęp.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Rozdziały teoretyczne</h4>
                <p class="text-sm text-slate-600">Synteza vs kompilacja — jak pisać, żeby nie było zlepkiem cytatów. Definiowanie pojęć. Głos autora.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Metodologia i badania</h4>
                <p class="text-sm text-slate-600">Pytania badawcze, hipotezy, zmienne. Metody, techniki, narzędzia. Dobór próby. Analiza wyników.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Zakończenie</h4>
                <p class="text-sm text-slate-600">Zakończenie vs podsumowanie. Odniesienie do celów. Perspektywy dalszych badań.</p>
              </div>
            </div>
          </div>
          
          <!-- Kolumna 2 -->
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
              <span class="w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center text-sm font-bold">3</span>
              Warsztat pisarski
            </h3>
            <div class="space-y-4 ml-10">
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Cytaty i cytowania</h4>
                <p class="text-sm text-slate-600">Kiedy cytować, kiedy parafrazować. System harwardzki i przypisy dolne — oba z przykładami. Jak uniknąć plagiatu.</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Bibliografia</h4>
                <p class="text-sm text-slate-600">Jak opisać książkę, artykuł, stronę www, akt prawny. Programy do bibliografii (Zotero, Mendeley).</p>
              </div>
              <div class="border-l-2 border-primary-200 pl-4">
                <h4 class="font-bold text-slate-900">Formatowanie w Word</h4>
                <p class="text-sm text-slate-600">Marginesy, czcionka, interlinia. Automatyczny spis treści. Numerowanie stron. Style nagłówków.</p>
