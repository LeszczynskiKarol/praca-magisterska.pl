---
// src/pages/sklep/index.astro
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";

const API_URL =
  "https://kiv8tougqc.execute-api.eu-central-1.amazonaws.com/prod";

// ====== ZMIEŃ TEN URL NA SWÓJ PLIK PREVIEW Z S3 ======
const PREVIEW_PDF_URL =
  "https://praca-magisterska-ebooks.s3.eu-central-1.amazonaws.com/jak-napisac-prac%C4%99-licencjacka-ebook.pdf";

const ebook = {
  id: "ebook-pisanie-pracy-licencjackiej",
  name: "Jak napisać pracę licencjacką",
  subtitle: "Kompletny przewodnik od A do Z",
  price: 29,
  pages: "250",
  chapters: 18,
  format: "PDF",
};
---

<Layout
  title="Ebook PDF: Książka „Jak napisać pracę licencjacką” - Poradnik 250 stron | Pisanie pracy licencjackiej krok po kroku"
  description="Kompletny poradnik pisania pracy licencjackiej w PDF. 250 stron praktycznej wiedzy: wybór tematu, przegląd literatury, metodologia badań, formatowanie, obrona. Szablony, checklisty, przykłady. Tylko 29 zł."
>
  <Navbar />

  <main class="min-h-screen">
    <!-- ============ HERO ============ -->
    <section
      class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-16 md:py-24"
    >
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex flex-wrap gap-2 mb-6">
              <span
                class="bg-accent/20 text-accent px-3 py-1 rounded-full text-sm font-medium"
                >📚 Ebook PDF</span
              >
              <span
                class="bg-white/10 text-white px-3 py-1 rounded-full text-sm"
                >250 stron</span
              >
              <span
                class="bg-white/10 text-white px-3 py-1 rounded-full text-sm"
                >18 rozdziałów</span
              >
            </div>

            <h1
              class="text-4xl md:text-5xl font-bold mb-4 leading-tight text-white"
            >
              Jak napisać pracę licencjacką
            </h1>
            <p class="text-2xl text-accent font-medium mb-4">
              Kompletny przewodnik od A do Z
            </p>
            <p class="text-slate-300 mb-6 leading-relaxed text-lg">
              Przestań się stresować i błądzić po omacku. Ten poradnik
              przeprowadzi Cię <strong class="text-white">krok po kroku</strong> przez
              cały proces pisania pracy licencjackiej — od wyboru tematu, przez przegląd
              literatury i metodologię badań, aż po formatowanie w Wordzie i obronę
              przed komisją.
            </p>

            <p class="text-slate-400 mb-8">
              <strong class="text-white">Zacznij pisać już dziś.</strong> Bez stresu.
              Bez marnowania czasu. Za cenę 3 kaw ☕
            </p>

            <div
              class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8"
            >
              <div class="bg-white/10 rounded-xl px-6 py-3">
                <span class="text-4xl font-bold text-white ml-2"
                  >{ebook.price} zł</span
                >
              </div>
              <button
                class="buy-button bg-accent hover:bg-green-600 text-white font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 flex items-center gap-2 shadow-lg shadow-accent/30 text-lg"
                data-product-id={ebook.id}
              >
                <span>Kup teraz i zacznij pisać</span>
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </button>
            </div>

            <div class="flex flex-wrap gap-4 text-sm text-slate-400">
              <span class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Dostęp w 30 sekund
              </span>
              <span class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Bezpieczna płatność
              </span>
              <span class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                PDF na każde urządzenie
              </span>
            </div>
          </div>

          <div class="relative">
            <div
              class="bg-gradient-to-br from-primary-500 to-accent rounded-2xl p-8 shadow-2xl transform md:rotate-2 hover:rotate-0 transition-transform"
            >
              <div class="bg-white rounded-lg p-6">
                <div class="text-center">
                  <div class="text-6xl mb-4">📘</div>
                  <h3 class="text-xl font-bold text-slate-800 mb-2">
                    {ebook.name}
                  </h3>
                  <p class="text-slate-500 text-sm">{ebook.subtitle}</p>
                  <div
                    class="mt-4 pt-4 border-t border-slate-200 flex justify-center gap-4 text-xs text-slate-400"
                  >
                    <span>PDF</span>
                    <span>•</span>
                    <span>250 stron</span>
                    <span>•</span>
                    <span>2026</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SOCIAL PROOF BAR ============ -->
    <section class="bg-accent py-4">
      <div class="max-w-6xl mx-auto px-4">
        <div
          class="flex flex-wrap justify-center gap-8 text-white text-sm font-medium"
        >
          <span>✓ Ponad 250+ stron</span>
          <span>✓ Uniwersalny dla każdego kierunku</span>
          <span>✓ Aktualizowany na 2026</span>
        </div>
      </div>
    </section>

    <!-- ============ PROBLEM INTRO ============ -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
          Pisanie pracy licencjackiej Cię przytłacza?
        </h2>
        <p class="text-xl text-slate-600 mb-8 leading-relaxed">
          Nie wiesz od czego zacząć. Promotor nie pomaga. Termin się zbliża.
          Siedzisz przed pustym dokumentem i czujesz, jak stres rośnie z każdym
          dniem.
        </p>
        <p class="text-lg text-slate-700 font-medium">
          <strong>Brzmi znajomo?</strong> Nie jesteś sam. Większość studentów przez
          to przechodzi. Ale nie musi tak być.
        </p>
      </div>
    </section>

    <!-- ============ LISTA PROBLEMÓW ============ -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">
          Ten ebook jest dla Ciebie, jeśli:
        </h2>
        <p class="text-center text-slate-600 mb-12">
          Zaznacz w głowie, ile z tych punktów Cię dotyczy 👇
        </p>

        <div class="grid md:grid-cols-2 gap-4">
          {
            [
              "Nie wiesz, od czego zacząć pisanie pracy",
              "Masz temat, ale nie wiesz jak go zawęzić do sensownego zakresu",
              "Nie wiesz, jakie elementy muszą znaleźć się w Twojej pracy",
              "Brakuje Ci motywacji do pisania",
              "Nie wiesz, gdzie szukać literatury naukowej",
              "Masz problem z odróżnieniem dobrego źródła od śmieciowego",
              "Twoja część teoretyczna to zlepek cytatów bez sensu",
              "Nie rozumiesz różnicy między przypisami a bibliografią",
              "Promotor każe poprawiać, ale nie mówi konkretnie co",
              "Nie umiesz formatować w Wordzie (spis treści, numeracja...)",
              "Boisz się plagiatu i systemu antyplagiatowego",
              "Nie wiesz jak sformułować pytania badawcze i hipotezy",
              "Boisz się obrony — co jeśli zapytają o coś trudnego?",
              "Nie chcesz czytać nudnych, akademickich poradników",
              "Chcesz konkrety do błyskawicznego zastosowania",
              "Chcesz zaoszczędzić dziesiątki godzin błądzenia po omacku",
            ].map((item) => (
              <div class="bg-white p-4 rounded-lg border border-slate-200 flex items-start gap-3">
                <span class="text-red-500 text-xl">☐</span>
                <span class="text-slate-700">{item}</span>
              </div>
            ))
          }
        </div>

        <div class="text-center mt-12">
          <p class="text-xl text-slate-800 font-medium mb-4">
            Jeśli zaznaczyłeś chociaż <strong>3 punkty</strong> — ten ebook rozwiąże
            Twoje problemy.
          </p>
          <p class="text-slate-600">
            Wszystkie te kwestie są szczegółowo omówione na 250 stronach
            praktycznej wiedzy.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ DLA KOGO NIE JEST ============ -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-green-50 border-2 border-green-200 rounded-2xl p-8">
            <h3
              class="text-xl font-bold text-green-800 mb-6 flex items-center gap-2"
            >
              <span class="text-2xl">✅</span> Ten ebook JEST dla Ciebie, jeśli:
            </h3>
            <ul class="space-y-4 text-slate-700">
              <li class="flex items-start gap-3">
                <span class="text-green-600 font-bold">+</span>
                <span
                  >Chcesz napisać pracę samodzielnie, ale potrzebujesz
                  przewodnika</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 font-bold">+</span>
                <span
                  >Jesteś gotowy włożyć wysiłek, ale chcesz wiedzieć JAK</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 font-bold">+</span>
                <span
                  >Cenisz swój czas i wolisz uczyć się na cudzych błędach</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 font-bold">+</span>
                <span>Szukasz konkretów, nie akademickiego bełkotu</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 font-bold">+</span>
                <span>Chcesz obronić się z czystym sumieniem</span>
              </li>
            </ul>
          </div>

          <div class="bg-red-50 border-2 border-red-200 rounded-2xl p-8">
            <h3
              class="text-xl font-bold text-red-800 mb-6 flex items-center gap-2"
            >
              <span class="text-2xl">❌</span> Ten ebook NIE jest dla Ciebie, jeśli:
            </h3>
            <ul class="space-y-4 text-slate-700">
              <li class="flex items-start gap-3">
                <span class="text-red-600 font-bold">−</span>
                <span>Szukasz kogoś, kto napisze pracę za Ciebie</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-600 font-bold">−</span>
                <span>Chcesz gotowca do skopiowania</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-600 font-bold">−</span>
                <span>Nie zamierzasz włożyć żadnego wysiłku</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-600 font-bold">−</span>
                <span>Jesteś ekspertem od pisania prac naukowych</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-red-600 font-bold">−</span>
                <span>Już obroniłeś pracę i znasz wszystkie zasady</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DLACZEGO TEN EBOOK ============ -->
    <section class="py-16 bg-slate-900 text-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl text-white font-bold text-center mb-4">
          Dlaczego akurat TEN ebook?
        </h2>
        <p class="text-center text-slate-400 mb-12">
          W internecie jest mnóstwo darmowych poradników. Czym ten się różni?
        </p>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-slate-800 rounded-xl p-6">
            <h3 class="text-xl text-white font-bold text-red-400 mb-4">
              ❌ Typowe darmowe poradniki:
            </h3>
            <ul class="space-y-3 text-slate-400">
              <li>• Ogólniki w stylu "napisz dobry wstęp"</li>
              <li>• Brak konkretnych przykładów</li>
              <li>• Akademicki język, który usypia</li>
              <li>• Informacje rozproszone po 100 stronach</li>
              <li>• Nieaktualne (sprzed 10 lat)</li>
              <li>• Pisane przez teoretyków</li>
            </ul>
          </div>

          <div class="bg-slate-800 rounded-xl p-6 border-2 border-accent">
            <h3 class="text-xl font-bold text-accent mb-4">✅ Ten ebook:</h3>
            <ul class="space-y-3 text-slate-300">
              <li>• <strong>Konkretne instrukcje</strong> krok po kroku</li>
              <li>
                • <strong>Dziesiątki przykładów</strong> z różnych kierunków
              </li>
              <li>• <strong>Prosty język</strong> bez akademickiego bełkotu</li>
              <li>• <strong>Wszystko w jednym miejscu</strong> — 250 stron</li>
              <li>• <strong>Aktualizowany na 2026</strong> rok</li>
              <li>• Pisany przez praktyków, nie teoretyków</li>
            </ul>
          </div>
        </div>

        <div class="text-center mt-12">
          <p class="text-slate-400 mb-4">
            Możesz spędzić <strong class="text-white">20 godzin</strong> szukając
            informacji w internecie i składając je w całość...
          </p>
          <p class="text-xl text-white font-medium">
            ...albo kupić ten ebook za <strong class="text-accent">29 zł</strong
            > i mieć wszystko gotowe w 5 minut.
          </p>
        </div>
      </div>
    </section>

    <!-- ============ CO ZAWIERA - MEGA SZCZEGÓŁOWO ============ -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">
          Co dokładnie znajdziesz w ebooku?
        </h2>
        <p class="text-center text-slate-600 mb-12">
          250 stron podzielonych na 4 części + dodatki z szablonami
        </p>

        <!-- CZĘŚĆ 1 -->
        <div class="mb-12 bg-slate-50 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <span
              class="bg-primary-600 text-white px-4 py-2 rounded-lg font-bold text-lg"
              >CZĘŚĆ I</span
            >
            <h3 class="text-2xl font-bold text-slate-900">
              Zanim zaczniesz pisać
            </h3>
            <span class="text-slate-500">(~80 stron)</span>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                📍 Rozdział 2: Wybór tematu
              </h4>
              <p class="text-slate-600 mb-4">
                Najważniejsza decyzja, którą podejmiesz. Zły temat = miesiące
                męczarni.
              </p>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>
                  ✓ <strong>6 sprawdzonych źródeł</strong> pomysłów na temat
                </li>
                <li>
                  ✓ <strong>Technika zawężania tematu</strong> — od "Zarządzanie"
                  do konkretnego problemu badawczego (5 poziomów z przykładami)
                </li>
                <li>✓ Jak sprawdzić, czy temat nie jest "przerobiony"</li>
                <li>
                  ✓ <strong>7 pytań kontrolnych</strong> przed wyborem tematu
                </li>
                <li>✓ Jak rozmawiać z promotorem o temacie</li>
                <li>✓ Cechy dobrego vs złego tytułu (przykłady)</li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                📚 Rozdział 3: Przegląd literatury
              </h4>
              <p class="text-slate-600 mb-4">
                Gdzie szukać źródeł i jak nie utopić się w materiałach.
              </p>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>
                  ✓ <strong>Tabela 15+ baz danych naukowych</strong> z linkami i charakterystyką
                </li>
                <li>
                  ✓ Google Scholar — jak używać (operatory, filtry, cytowania)
                </li>
                <li>
                  ✓ <strong>Metoda "śnieżnej kuli"</strong> — znajdź 50 źródeł zaczynając
                  od 1
                </li>
                <li>
                  ✓ <strong>Tabela "Co cytować, czego unikać"</strong> — Wikipedia,
                  blogi, czasopisma drapieżne
                </li>
                <li>✓ System notatek i fiszek (wzór do skopiowania)</li>
                <li>✓ Ile pozycji w bibliografii? (konkretne liczby)</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- CZĘŚĆ 2 -->
        <div class="mb-12 bg-slate-50 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <span
              class="bg-primary-600 text-white px-4 py-2 rounded-lg font-bold text-lg"
              >CZĘŚĆ II</span
            >
            <h3 class="text-2xl font-bold text-slate-900">
              Struktura pracy — co gdzie pisać
            </h3>
            <span class="text-slate-500">(~100 stron)</span>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                ✍️ Rozdziały 5-7: Wstęp i teoria
              </h4>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>✓ <strong>Checklist: co MUSI być we wstępie</strong></li>
                <li>✓ Kiedy pisać wstęp? (spoiler: NA KOŃCU!)</li>
                <li>
                  ✓ <strong>Synteza vs kompilacja</strong> — jak pisać, żeby nie było
                  "zlepkiem cytatów"
                </li>
                <li>✓ Przykład złego i dobrego tekstu teoretycznego</li>
                <li>✓ Jak definiować pojęcia (2-4 definicje + uzasadnienie)</li>
                <li>
                  ✓ <strong>Zdania łączące</strong> między akapitami (gotowe formuły)
                </li>
                <li>✓ Proporcje rozdziałów (teoria 40-50%)</li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                🔬 Rozdziały 8-10: Badania i zakończenie
              </h4>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>
                  ✓ Jak sformułować <strong>pytania badawcze i hipotezy</strong>
                </li>
                <li>
                  ✓ <strong>Różnica między metodą, techniką a narzędziem</strong
                  >
                </li>
                <li>✓ Jak dobrać próbę badawczą</li>
                <li>✓ Jak prezentować wyniki (tabele, wykresy)</li>
                <li>✓ Co jeśli hipoteza się nie potwierdziła?</li>
                <li>
                  ✓ <strong>Zakończenie vs podsumowanie</strong> — różnica
                </li>
                <li>✓ Jak odnieść się do celów ze wstępu</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- CZĘŚĆ 3 -->
        <div class="mb-12 bg-slate-50 rounded-2xl p-8">
          <div class="flex items-center gap-4 mb-6">
            <span
              class="bg-primary-600 text-white px-4 py-2 rounded-lg font-bold text-lg"
              >CZĘŚĆ III</span
            >
            <h3 class="text-2xl font-bold text-slate-900">
              Warsztat pisarski i redakcja
            </h3>
            <span class="text-slate-500">(~80 stron)</span>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                📝 Rozdziały 11-14: Cytaty i bibliografia
              </h4>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>✓ Kiedy cytować dosłownie, kiedy parafrazować?</li>
                <li>
                  ✓ <strong>System harwardzki</strong> — wszystkie przypadki z przykładami
                </li>
                <li>
                  ✓ <strong>Przypisy dolne</strong> — ibidem, op.cit., tamże
                </li>
                <li>✓ Jak cytować: książkę, artykuł, stronę www, akt prawny</li>
                <li>✓ <strong>Jak nie wpaść w plagiat</strong></li>
                <li>✓ Co wykrywa system antyplagiatowy</li>
                <li>✓ Zotero i Mendeley — jak używać</li>
              </ul>
            </div>

            <div>
              <h4 class="font-bold text-slate-900 mb-4 text-lg">
                💻 Rozdział 15: Formatowanie w Word
              </h4>
              <ul class="space-y-2 text-slate-700 text-sm">
                <li>
