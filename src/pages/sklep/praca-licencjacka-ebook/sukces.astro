---
// src/pages/sklep/praca-licencjacka-ebook/sukces.astro
import Footer from "../../../components/Footer.astro";
import Navbar from "../../../components/Navbar.astro";
import Layout from "../../../layouts/Layout.astro";

const API_URL = "https://kiv8tougqc.execute-api.eu-central-1.amazonaws.com/prod";
---

<Layout
  title="Dziękujemy za zakup! - Praca-Magisterska.pl"
  description="Twój zakup został zrealizowany pomyślnie."
>
  <Navbar />

  <main class="min-h-screen bg-gray-50 flex items-center justify-center py-16">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 mb-4">🎉 Dziękujemy za zakup!</h1>

        <p class="text-gray-600 mb-6">
          Twoja płatność została zrealizowana pomyślnie.
        </p>

        <!-- Download section -->
        <div id="download-section" class="mb-8">
          <div id="download-loading" class="bg-blue-50 border border-blue-200 rounded-xl p-6">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600 mx-auto mb-3"></div>
            <p class="text-sm text-blue-800">Przygotowuję link do pobrania...</p>
          </div>
          <div id="download-ready" class="hidden">
            <a id="download-link" href="#" class="block w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-xl transition-colors text-lg mb-3">
              📥 Pobierz ebook
            </a>
            <p class="text-xs text-gray-500">Link ważny 24 godziny. Sprawdź też email — wysłaliśmy kopię zapasową.</p>
          </div>
          <div id="download-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4">
            <p class="text-sm text-red-800"><strong>Wystąpił błąd.</strong> Sprawdź email — link do pobrania powinien dotrzeć w ciągu kilku minut. Sprawdź też SPAM.</p>
          </div>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-8">
          <p class="text-sm text-amber-800">
            <strong>💡 Wskazówka na start:</strong><br />
            Zacznij od rozdziału 2 (Wybór tematu) — to fundament, który zaoszczędzi Ci tygodnie pracy!
          </p>
        </div>

        <div class="space-y-4">
          <a href="/sklep" class="block w-full bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-6 rounded-xl transition-colors">Wróć do sklepu</a>
          <a href="/" class="block w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 px-6 rounded-xl transition-colors">Strona główna</a>
        </div>

        <p class="text-sm text-gray-500 mt-8">
          Masz pytania? <a href="mailto:kontakt@praca-magisterska.pl" class="text-primary-600 hover:underline">kontakt@praca-magisterska.pl</a>
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script define:vars={{ API_URL }}>
// @ts-nocheck
// cSpell:ignore gtag
(function() {
  'use strict';
  var PRODUCTS = {
    'ebook-pisanie-pracy-licencjackiej': { name: 'Jak napisać pracę licencjacką', price: 29.00 },
    'ebook-pisanie-pracy-magisterskiej': { name: 'Jak napisać pracę magisterską od A do Z', price: 39.00 },
  };
  var params = new URLSearchParams(window.location.search);
  var sessionId = params.get('session_id');
  var productId = params.get('productId');
  if (sessionId) {
    var product = (productId && PRODUCTS[productId]) ? PRODUCTS[productId] : { name: 'Ebook', price: 0 };
    var storageKey = 'purchase_tracked_' + sessionId;
    try { if (!sessionStorage.getItem(storageKey)) {
      function fire() {
        if (typeof window.gtag !== 'function') return false;
        window.gtag('event', 'purchase', { transaction_id: sessionId, value: product.price, currency: 'PLN', items: [{ item_id: productId || 'unknown', item_name: product.name, price: product.price, quantity: 1, item_category: 'Ebook' }] });
        try { sessionStorage.setItem(storageKey, '1'); } catch(e) {}
        return true;
      }
      if (!fire()) { var a = 0; var i = setInterval(function() { a++; if (fire() || a >= 20) clearInterval(i); }, 500); }
    }} catch(e) {}
  }
  var loadingEl = document.getElementById('download-loading');
  var readyEl = document.getElementById('download-ready');
  var errorEl = document.getElementById('download-error');
  var linkEl = document.getElementById('download-link');
  if (!sessionId) { loadingEl.classList.add('hidden'); errorEl.classList.remove('hidden'); return; }
  fetch(API_URL + '/get-download', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sessionId: sessionId }) })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    loadingEl.classList.add('hidden');
    if (data.downloadUrl) { linkEl.href = data.downloadUrl; linkEl.textContent = '📥 Pobierz: ' + (data.productName || 'Ebook'); readyEl.classList.remove('hidden'); }
    else { errorEl.classList.remove('hidden'); }
  })
  .catch(function() { loadingEl.classList.add('hidden'); errorEl.classList.remove('hidden'); });
})();
</script>
