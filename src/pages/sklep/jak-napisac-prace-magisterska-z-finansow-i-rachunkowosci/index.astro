---
// src/pages/sklep/jak-napisac-prace-magisterska-z-finansow-i-rachunkowosci/index.astro
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Footer from "../../../components/Footer.astro";

const API_URL =
  "https://kiv8tougqc.execute-api.eu-central-1.amazonaws.com/prod";

const PREVIEW_PDF_URL =
  "https://praca-magisterska-ebooks.s3.eu-central-1.amazonaws.com/jak-napisac-prace-magisterska-z-finansow-i-rachunkowosci-preview.pdf";

const ebook = {
  id: "ebook-magisterska-finanse",
  name: "Jak napisać pracę magisterską z finansów i rachunkowości",
  subtitle: "Od sprawozdania do obrony — kompletny przewodnik",
  price: 49,
  chapters: 16,
  format: "PDF + EPUB",
};
---

<Layout
  title="Ebook: Jak napisać pracę magisterską z finansów i rachunkowości | Przewodnik PDF + EPUB"
  description="Praktyczny przewodnik po pisaniu pracy magisterskiej z finansów i rachunkowości. Analiza sprawozdań, wskaźniki, modele dyskryminacyjne, interpretacja, rekomendacje. PDF + EPUB za 49 zł."
>
  <Navbar />

  <main class="min-h-screen">
    <!-- HERO -->
    <section class="bg-gradient-to-br from-stone-900 via-amber-950 to-stone-900 text-white py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="bg-accent/30 text-accent-light px-3 py-1 rounded-full text-sm font-medium">📚 PDF + EPUB</span>
              <span class="bg-white/10 text-white px-3 py-1 rounded-full text-sm">Finanse i rachunkowość</span>
              <span class="bg-white/10 text-white px-3 py-1 rounded-full text-sm">{ebook.chapters} rozdziałów</span>
              <span class="bg-gradient-to-r from-amber-400 to-yellow-400 text-white px-3 py-1 rounded-full text-sm font-medium">✨ Wydanie 2026</span>
            </div>

            <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight text-white">
              {ebook.name}
            </h1>
            <p class="text-2xl text-accent-light font-medium mb-4">
              {ebook.subtitle}
            </p>
            <p class="text-amber-100 mb-6 leading-relaxed text-lg">
              Magisterka z finansów żyje liczbami: <strong class="text-white">sprawozdania, wskaźniki, modele — i interpretacja, która odróżnia analizę od kalkulatora</strong>. Ten przewodnik prowadzi przez cały warsztat: od pobrania raportów, przez analizę wskaźnikową i modele, po sąd o kondycji i rekomendacje.
            </p>

            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
              <div class="bg-white/10 rounded-xl px-6 py-3">
                <span class="text-4xl font-bold text-white ml-2">{ebook.price} zł</span>
              </div>
              <button
                class="buy-button bg-gradient-to-r from-amber-600 to-yellow-500 hover:from-yellow-500 hover:to-amber-600 text-white font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 flex items-center gap-2 shadow-lg shadow-amber-500/30 text-lg"
                data-product-id={ebook.id}
              >
                <span>Kup przewodnik</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </button>
            </div>

            <div class="flex flex-wrap gap-4 text-sm text-amber-200">
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Dostęp w 30 sekund
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Bezpieczna płatność Stripe
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                PDF + EPUB na każde urządzenie
              </span>
            </div>
          </div>

          <div class="relative">
            <div class="bg-gradient-to-br from-amber-800 to-stone-800 rounded-2xl p-8 shadow-2xl transform md:rotate-2 hover:rotate-0 transition-transform">
              <div class="bg-white rounded-lg p-6">
                <div class="text-center">
                  <div class="text-6xl mb-4">💰</div>
                  <h3 class="text-xl font-bold text-slate-800 mb-2">{ebook.name}</h3>
                  <p class="text-slate-500 text-sm">{ebook.subtitle}</p>
                  <div class="mt-4 pt-4 border-t border-slate-200 flex justify-center gap-4 text-xs text-slate-400">
                    <span>PDF + EPUB</span>
                    <span>•</span>
                    <span>{ebook.chapters} rozdziałów</span>
                    <span>•</span>
                    <span>Wydanie I · 2026</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CO ZNAJDZIESZ -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-4">Co znajdziesz w przewodniku?</h2>
        <p class="text-center text-slate-600 mb-12">
          Materiał przygotowany specjalnie pod wymagania pracy magisterskiej z finansów i rachunkowości.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          {
            [
              {
                icon: "📑",
                title: "Sprawozdania jako materiał",
                desc: "eKRS, raporty roczne, noty i opinia biegłego — jak skompletować dane i zbudować arkusz analityczny.",
              },
              {
                icon: "📊",
                title: "Wskaźniki bez wskaźnikozy",
                desc: "Cztery obszary, 12–15 miar z jawną formułą, Du Pont i cykl konwersji gotówki — mniej liczenia, więcej rozumienia.",
              },
              {
                icon: "💧",
                title: "Bilans, wynik i przepływy razem",
                desc: "Memoriał vs kasa, jakość zysku, synteza krzyżowa trzech elementów sprawozdania.",
              },
              {
                icon: "⚠️",
                title: "Modele dyskryminacyjne z głową",
                desc: "Polskie modele zamiast wyroczni z importu: postaci funkcji, trajektorie, granice stosowalności.",
              },
              {
                icon: "🎯",
                title: "Interpretacja i synteza oceny",
                desc: "Trzy kroki interpretacji, triangulacja ustaleń, perspektywa interesariusza i sąd bez parasolek.",
              },
              {
                icon: "🎤",
                title: "Rekomendacje i obrona",
                desc: "Rekomendacje z rodowodem i wykonalnością, kanon pytań komisji („dlaczego zysk to nie gotówka?”).",
              },
            ].map((item) => (
              <div class="bg-slate-50 p-6 rounded-xl border border-slate-200 hover:border-accent transition-colors">
                <div class="text-3xl mb-3">{item.icon}</div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
                <p class="text-slate-600 text-sm">{item.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PREVIEW PDF -->
    <section class="py-16 bg-gradient-to-br from-stone-900 via-amber-950 to-stone-900">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold text-white mb-4">
            📖 Zajrzyj do środka — przeczytaj fragment za darmo
          </h2>
          <p class="text-amber-200">
            Okładka, pełny spis treści i cały pierwszy rozdział do przejrzenia.
          </p>
        </div>

        <!-- PDF EMBED -->
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
          <div class="bg-stone-900 px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <span class="text-sm text-amber-200">Fragment przewodnika — spis treści i rozdział 1</span>
            </div>
            <a
              href={PREVIEW_PDF_URL}
              target="_blank"
              class="text-sm text-accent-light hover:text-white flex items-center gap-1"
            >
              Otwórz w nowej karcie ↗
            </a>
          </div>

          <iframe
            src={PREVIEW_PDF_URL}
            class="w-full h-[600px] md:h-[700px] border-0"
            title="Preview przewodnika — finanse i rachunkowość"></iframe>
        </div>

        <div class="text-center mt-8">
          <p class="text-amber-200 mb-6">
            Podoba Ci się? To zaledwie <strong class="text-white">1 z {ebook.chapters} rozdziałów</strong> pisanych z tą samą gęstością konkretu.
          </p>
          <button
            class="buy-button bg-gradient-to-r from-amber-600 to-yellow-500 hover:from-yellow-500 hover:to-amber-600 text-white font-bold py-4 px-10 rounded-xl transition-all hover:scale-105 inline-flex items-center gap-2 shadow-lg shadow-amber-500/30 text-lg"
            data-product-id={ebook.id}
          >
            <span>Kup pełny przewodnik za {ebook.price} zł</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- DLA KOGO -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-8">Ten przewodnik jest dla Ciebie, jeśli:</h2>

        <div class="space-y-4">
          {
            [
              "Masz temat „analiza finansowa spółki X”, ale nie wiesz, od czego zacząć",
              "Boisz się, że praca wyjdzie kalkulatorem: sto liczb i zero wniosków",
              "Nie wiesz, które wskaźniki wybrać i jak je liczyć konsekwentnie",
              "Modele Altmana i polskie funkcje Z brzmią groźnie — a komisja o nie zapyta",
              "Nie wiesz, jak interpretować: „wskaźnik wynosi 1,1” to dla Ciebie koniec zdania",
              "Chcesz rekomendacji, które zarząd mógłby wziąć na naradę",
              "Zależy Ci na pracy-portfolio na rozmowy do banku, funduszu czy kontrolingu",
            ].map((item) => (
              <div class="flex items-start gap-3 bg-white p-4 rounded-lg border border-slate-200">
                <span class="text-accent text-xl">✓</span>
                <span class="text-slate-700">{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gradient-to-br from-stone-900 via-amber-950 to-stone-900">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-6 text-white">Gotowy napisać magisterkę z finansów?</h2>
        <p class="text-xl text-amber-200 mb-8">
          Za cenę jednej kawy ☕ dostajesz warsztat, za który ten rynek płaci najlepiej: przeczytać, policzyć, zinterpretować.
        </p>

        <div class="bg-stone-900/60 rounded-2xl p-8 max-w-lg mx-auto mb-8">
          <div class="text-5xl font-bold mb-2 text-white">{ebook.price} zł</div>
          <p class="text-accent-light font-medium mb-6">Jednorazowa płatność • PDF + EPUB natychmiast po zakupie</p>

          <button
            class="buy-button w-full bg-gradient-to-r from-amber-600 to-yellow-500 hover:from-yellow-500 hover:to-amber-600 text-white font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 flex items-center justify-center gap-2 shadow-lg shadow-amber-500/30 text-lg"
            data-product-id={ebook.id}
          >
            <span>Kupuję przewodnik</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>
        </div>

        <p class="text-sm text-amber-300">
          Potrzebujesz bardziej uniwersalnego poradnika? Sprawdź
          <a href="/sklep/praca-magisterska-ebook/" class="text-accent-light hover:underline">„Jak napisać pracę magisterską od A do Z”</a>.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-slate-900 mb-12">Najczęściej zadawane pytania</h2>

        <div class="space-y-4">
          <details class="bg-slate-50 rounded-xl p-6 group">
            <summary class="font-semibold text-slate-900 cursor-pointer flex justify-between items-center">
              Czy przewodnik pasuje do pracy porównawczej albo o upadłościach?
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <p class="mt-4 text-slate-600">
              Tak — obok klasycznej analizy jednej spółki przewodnik rozpisuje szkielety pracy porównawczej (z zasadami porównywalności) i pracy testującej modele dyskryminacyjne na próbie spółek upadłych, wraz z rygorami każdej z nich.
            </p>
          </details>

          <details class="bg-slate-50 rounded-xl p-6 group">
            <summary class="font-semibold text-slate-900 cursor-pointer flex justify-between items-center">
              W jakich formatach dostanę ebooka?
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <p class="mt-4 text-slate-600">
              W paczce ZIP dostajesz <strong>PDF</strong> (ładny układ do czytania na komputerze i druku) i <strong>EPUB</strong> (wygodny na czytniku i telefonie).
            </p>
          </details>

          <details class="bg-slate-50 rounded-xl p-6 group">
            <summary class="font-semibold text-slate-900 cursor-pointer flex justify-between items-center">
              Jak szybko dostanę plik po zakupie?
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            <p class="mt-4 text-slate-600">
              <strong>Natychmiast.</strong> Po udanej płatności otrzymasz email z linkiem do pobrania w ciągu 30–60 sekund. Link jest ważny 7 dni.
            </p>
          </details>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Loading overlay -->
  <div
    id="loading-overlay"
    class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden"
  >
    <div class="bg-white rounded-2xl p-8 text-center">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-amber-700 mx-auto mb-4"></div>
      <p class="text-slate-700">Przekierowuję do płatności...</p>
    </div>
  </div>

  <script define:vars={{ API_URL }}>
    // cSpell:ignore gtag
    document.addEventListener("DOMContentLoaded", function () {
      var PRODUCTS = {
        "ebook-magisterska-finanse": {
          name: "Jak napisać pracę magisterską z finansów i rachunkowości",
          price: 49.0,
        },
      };

      var buttons = document.querySelectorAll(".buy-button");
      var loadingOverlay = document.getElementById("loading-overlay");

      buttons.forEach(function (button) {
        button.addEventListener("click", async function () {
          var productId = button.dataset.productId;
          var product = PRODUCTS[productId] || { name: "Ebook", price: 0 };

          // GA4: add_to_cart + begin_checkout
          if (typeof window.gtag === "function") {
            var gaItem = {
              item_id: productId,
              item_name: product.name,
              price: product.price,
              quantity: 1,
              item_category: "Ebook kierunkowy",
            };
            window.gtag("event", "add_to_cart", {
              value: product.price,
              currency: "PLN",
              items: [gaItem],
            });
            window.gtag("event", "begin_checkout", {
              value: product.price,
              currency: "PLN",
              items: [gaItem],
            });
          }

          loadingOverlay.classList.remove("hidden");
          button.disabled = true;

          try {
            var response = await fetch(API_URL + "/create-checkout", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ productId: productId }),
            });
            var data = await response.json();
            if (data.url) {
              window.location.href = data.url;
            } else {
              throw new Error(data.error || "Błąd");
            }
          } catch (error) {
            console.error("Error:", error);
            loadingOverlay.classList.add("hidden");
            button.disabled = false;
            alert("Wystąpił błąd. Spróbuj ponownie.");
          }
        });
      });
    });
  </script>
</Layout>
