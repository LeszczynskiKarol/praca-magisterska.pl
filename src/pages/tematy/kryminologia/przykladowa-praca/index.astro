import DownloadBox from "../../../../components/DownloadBox.astro";
import InfoBox from "../../../../components/InfoBox.astro";

const breadcrumbs = [
  { label: "Kierunki", href: "/tematy/" },
  { label: "Kryminologia", href: "/tematy/kryminologia/" },
  { label: "Przykładowa praca", href: "/tematy/kryminologia/przykladowa-praca/" },
];

const relatedLinks = [
  { label: "Tematy prac z kryminologii", href: "/tematy/kryminologia/" },
  { label: "Rozdział metodologiczny", href: "/poradniki/metodologia/rozdzial-metodologiczny/" },
  { label: "Badania ilościowe", href: "/poradniki/metodologia/badania-ilosciowe/" },
  { label: "Cel i hipotezy pracy", href: "/poradniki/cel-pracy/" },
