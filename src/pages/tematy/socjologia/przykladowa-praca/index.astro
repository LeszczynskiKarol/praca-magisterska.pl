const breadcrumbs = [
  { label: "Kierunki", href: "/tematy/" },
  { label: "Socjologia", href: "/tematy/socjologia/" },
  { label: "Przykładowa praca", href: "/tematy/socjologia/przykladowa-praca/" },
];

const relatedLinks = [
  { label: "Tematy prac z socjologii", href: "/tematy/socjologia/" },
  { label: "Rozdział metodologiczny", href: "/poradniki/metodologia/rozdzial-metodologiczny/" },
  { label: "Badania ilościowe", href: "/poradniki/metodologia/badania-ilosciowe/" },
  { label: "Jak przeprowadzić ankietę", href: "/poradniki/metodologia/ankieta/" },
