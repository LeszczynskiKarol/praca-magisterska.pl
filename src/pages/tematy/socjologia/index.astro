  { label: "Kierunki", href: "/tematy/" },
  { label: "Socjologia", href: "/kierunki/socjologia/" },
];

const relatedLinks = [
  {
    label: "Jak napisać pracę magisterską",
    href: "/poradniki/jak-napisac-prace-magisterska/",
  },
