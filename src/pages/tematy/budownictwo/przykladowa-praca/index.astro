---
import ArticleLayout from "../../../../layouts/ArticleLayout.astro";
import DownloadBox from "../../../../components/DownloadBox.astro";
import InfoBox from "../../../../components/InfoBox.astro";

const breadcrumbs = [
  { label: "Kierunki", href: "/tematy/" },
  { label: "Budownictwo", href: "/tematy/budownictwo/" },
  { label: "Przykładowa praca", href: "/tematy/budownictwo/przykladowa-praca/" },
];

const relatedLinks = [
  { label: "Tematy prac z budownictwa", href: "/tematy/budownictwo/" },
  { label: "Przykładowa praca z informatyki", href: "/tematy/informatyka/przykladowa-praca/" },
  { label: "Tabele i wykresy w pracy", href: "/poradniki/tabele-wykresy/" },
  { label: "Jak napisać wstęp", href: "/poradniki/wstep/" },
  { label: "Wykaz tabel i rysunków", href: "/poradniki/wykaz-tabel/" },
  { label: "Struktura pracy magisterskiej", href: "/poradniki/struktura/" },
