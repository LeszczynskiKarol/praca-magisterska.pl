const relatedLinks = [
  { label: "Tematy prac z kulturoznawstwa", href: "/tematy/kulturoznawstwo/" },
  { label: "Przykładowa praca z filologii polskiej", href: "/tematy/filologia-polska/przykladowa-praca/" },
  { label: "Przykładowa praca z dziennikarstwa", href: "/tematy/dziennikarstwo/przykladowa-praca/" },
