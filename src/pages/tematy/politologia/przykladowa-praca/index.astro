const relatedLinks = [
  { label: "Tematy prac z politologii", href: "/tematy/politologia/" },
  { label: "Jak napisać wstęp", href: "/poradniki/wstep/" },
  { label: "Cel i teza pracy", href: "/poradniki/cel-pracy/" },
  { label: "Przypisy w pracy", href: "/poradniki/przypisy/" },
