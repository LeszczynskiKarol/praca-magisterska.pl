---
// src/pages/poradniki/index.astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SmartEduCTA from '../../components/SmartEduCTA.astro';

const categories = [
  {
    id: 'start',
    name: '🚀 Jak zacząć',
    description: 'Pierwsze kroki w pisaniu pracy',
    articles: [
      { title: 'Jak napisać pracę magisterską', description: 'Kompletny przewodnik krok po kroku: od tematu do obrony, z harmonogramem i wzorami PDF.', href: '/poradniki/jak-napisac-prace-magisterska/', icon: '🗺️', featured: true },
      { title: 'Wybór tematu pracy magisterskiej', description: 'Jak wybrać temat, który będzie interesujący i realny do zrealizowania.', href: '/poradniki/wybor-tematu/', icon: '💡' },
      { title: 'Jak znaleźć promotora', description: 'Kryteria wyboru, pierwsze spotkanie i czerwone flagi.', href: '/poradniki/znalezienie-promotora/', icon: '🤝' },
      { title: 'Konspekt pracy magisterskiej', description: 'Jak stworzyć plan pracy, który ułatwi pisanie.', href: '/poradniki/konspekt/', icon: '📋' },
      { title: 'Cel pracy magisterskiej', description: 'Jak prawidłowo sformułować cel główny i cele szczegółowe.', href: '/poradniki/cel-pracy/', icon: '🎯' },
      { title: 'Harmonogram pisania', description: 'Jak rozplanować pracę na miesiące i nie zostawić wszystkiego na koniec.', href: '/poradniki/harmonogram/', icon: '📅' },
    ],
  },
  {
    id: 'struktura',
    name: '📋 Struktura pracy',
    description: 'Elementy składowe pracy magisterskiej',
    articles: [
      { title: 'Struktura pracy magisterskiej', description: 'Rozdziały, podrozdziały i proporcje typowej pracy.', href: '/poradniki/struktura/', icon: '🏗️' },
      { title: 'Jak napisać wstęp', description: 'Struktura wstępu, kompletny przykład i wzór PDF do pobrania.', href: '/poradniki/wstep/', icon: '📝' },
      { title: 'Rozdział teoretyczny', description: 'Przegląd literatury, który prowadzi do problemu badawczego.', href: '/poradniki/rozdzial-teoretyczny/', icon: '📖' },
      { title: 'Spis treści', description: 'Jak stworzyć profesjonalny spis treści.', href: '/poradniki/spis-tresci/', icon: '📑' },
      { title: 'Streszczenie pracy', description: 'Jak napisać streszczenie w języku polskim i angielskim.', href: '/poradniki/streszczenie/', icon: '📃' },
      { title: 'Zakończenie pracy', description: 'Struktura zakończenia, wnioski i podsumowanie.', href: '/poradniki/zakonczenie/', icon: '✅' },
    ],
  },
  {
    id: 'badania',
    name: '🔬 Badania',
    description: 'Metodologia i prowadzenie badań',
    articles: [
      { title: 'Metodologia badań', description: 'Kompletny przewodnik po metodologii: metody, techniki, narzędzia.', href: '/poradniki/metodologia/', icon: '🔬', featured: true },
    ],
  },
  {
    id: 'pisanie',
    name: '✍️ Pisanie',
    description: 'Cytowanie, bibliografia i formatowanie',
    articles: [
      { title: 'Bibliografia', description: 'Style cytowania, tworzenie bibliografii i unikanie plagiatu.', href: '/poradniki/bibliografia/', icon: '📚' },
      { title: 'Styl APA', description: 'Cytowanie autor-data i wzory opisów według APA 7.', href: '/poradniki/bibliografia/apa/', icon: '🔤' },
      { title: 'Styl Harvard', description: 'Cytowanie autor-data i wzory bibliografii w stylu Harvard.', href: '/poradniki/bibliografia/harvard/', icon: '🎓' },
      { title: 'Styl Chicago', description: 'System przypisowy i bibliografia dla humanistyki.', href: '/poradniki/bibliografia/chicago/', icon: '🏛️' },
      { title: 'Przypisy', description: 'Przypisy dolne, tamże, ibidem, op. cit. - wzory i zasady.', href: '/poradniki/przypisy/', icon: '🔖' },
      { title: 'Cytowanie i cytaty', description: 'Jak prawidłowo cytować źródła.', href: '/poradniki/cytaty/', icon: '💬' },
      { title: 'Formatowanie pracy', description: 'Normy edytorskie, marginesy, czcionki, numeracja stron.', href: '/poradniki/formatowanie/', icon: '📄' },
      { title: 'Jak szukać źródeł', description: 'Google Scholar, polskie bazy, Scopus i ocena wiarygodności.', href: '/poradniki/zrodla/', icon: '🔍' },
      { title: 'Jak czytać artykuły naukowe', description: 'Czytanie nieliniowe, schemat IMRAD i system notatek.', href: '/poradniki/czytanie-artykulow/', icon: '📰' },
      { title: 'Język naukowy', description: 'Styl, formy bezosobowe, gotowe zwroty i częste błędy.', href: '/poradniki/jezyk-naukowy/', icon: '✍️' },
      { title: 'Tabele i wykresy', description: 'Tworzenie, opisywanie, numeracja i wybór typu wykresu.', href: '/poradniki/tabele-wykresy/', icon: '📊' },
      { title: 'Unikanie plagiatu', description: 'System JSA, współczynniki podobieństwa i jak go uniknąć.', href: '/poradniki/plagiat/', icon: '🛡️' },
      { title: 'Word - formatowanie', description: 'Style, automatyczny spis treści, numeracja i przypisy.', href: '/poradniki/word/', icon: '🖊️' },
      { title: 'LaTeX dla początkujących', description: 'Kiedy się opłaca, Overleaf, polskie znaki i bibliografia.', href: '/poradniki/latex/', icon: '🧮' },
      { title: 'Zotero', description: 'Zbieranie źródeł, wtyczka do Worda i generowanie bibliografii.', href: '/poradniki/zotero/', icon: '🗂️' },
      { title: 'Mendeley', description: 'Reference Manager, Mendeley Cite i porównanie z Zotero.', href: '/poradniki/mendeley/', icon: '🗃️' },
      { title: 'Pisanie po angielsku', description: 'Academic English, abstract i częste błędy Polaków.', href: '/poradniki/pisanie-angielski/', icon: '🌐' },
    ],
  },
  {
    id: 'finalizacja',
    name: '🎓 Finalizacja',
    description: 'Zakończenie i obrona pracy',
    articles: [
      { title: 'Obrona pracy magisterskiej', description: 'Przygotowanie do obrony, typowe pytania komisji.', href: '/poradniki/obrona/', icon: '🎓' },
      { title: 'Prezentacja na obronę', description: 'Struktura slajdów, liczba plansz, czas i zasady wizualne.', href: '/poradniki/prezentacja/', icon: '📽️' },
      { title: 'Typowe pytania na obronie', description: 'Lista najczęstszych pytań i strategia odpowiadania.', href: '/poradniki/pytania-obrona/', icon: '❓' },
      { title: 'Korekta i redakcja', description: 'Jak sprawdzić tekst przed oddaniem i lista kontrolna.', href: '/poradniki/korekta/', icon: '✏️' },
      { title: 'Sprawdzanie antyplagiatowe', description: 'JSA, przebieg procedury i jak czytać raport podobieństwa.', href: '/poradniki/antyplagiat/', icon: '🔎' },
      { title: 'Drukowanie i oprawa', description: 'Ile egzemplarzy, rodzaj oprawy i przygotowanie pliku PDF.', href: '/poradniki/drukowanie/', icon: '🖨️' },
      { title: 'Stres przed obroną', description: 'Jak opanować tremę i przygotować się na dzień obrony.', href: '/poradniki/stres/', icon: '🧘' },
      { title: 'Co dalej po obronie', description: 'Dyplom, suplement, formalności i dalsze ścieżki kariery.', href: '/poradniki/po-obronie/', icon: '🎉' },
    ],
  },
];

const metodologiaHighlights = [
  { title: 'Badania ilościowe', href: '/poradniki/metodologia/badania-ilosciowe/' },
  { title: 'Badania jakościowe', href: '/poradniki/metodologia/badania-jakosciowe/' },
  { title: 'Jak przeprowadzić ankietę', href: '/poradniki/metodologia/ankieta/' },
  { title: 'Jak przeprowadzić wywiad', href: '/poradniki/metodologia/wywiad/' },
];
---

<Layout 
  title="Poradniki pisania pracy magisterskiej — 30+ przewodników krok po kroku"
  description="Poradniki pisania pracy magisterskiej: wstęp, struktura, metodologia, badania, bibliografia, zakończenie i obrona. 30+ przewodników z przykładami i wzorami. Bezpłatnie."
>
  <Navbar />
  
  <main class="pt-20 md:pt-24">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-50 via-white to-accent/10 py-16">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto text-center">
          <span class="badge badge-primary mb-4">📖 Poradniki</span>
          <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6">
            Poradniki pisania pracy magisterskiej
          </h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Kompletny zbiór poradników dla studentów. Od wyboru tematu, przez badania i pisanie, aż po obronę.
          </p>
        </div>
      </div>
    </section>

    <!-- Quick Stats -->
    <section class="py-8 bg-white border-b border-gray-100">
      <div class="container-custom">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
          <div>
            <div class="text-3xl font-bold text-primary-600">15+</div>
            <div class="text-gray-600 text-sm">Poradników</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-primary-600">10+</div>
            <div class="text-gray-600 text-sm">Artykułów o metodologii</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-primary-600">100%</div>
            <div class="text-gray-600 text-sm">Za darmo</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Articles by Category -->
    <section class="py-16 bg-gray-50">
      <div class="container-custom">
        <div class="max-w-6xl mx-auto">
          {categories.map((category) => (
            <div class="mb-12 last:mb-0">
              <div class="flex flex-wrap items-center gap-2 mb-6">
                <h2 class="text-2xl font-bold text-gray-900">{category.name}</h2>
                <span class="text-gray-500 text-sm hidden sm:inline">— {category.description}</span>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {category.articles.map((article) => (
                  <a 
                    href={article.href} 
                    class={`card card-hover group ${'featured' in article && article.featured ? 'ring-2 ring-primary-400 bg-primary-50/50' : ''}`}
                  >
                    <div class="flex items-start gap-4">
                      <span class="text-3xl flex-shrink-0">{article.icon}</span>
                      <div class="flex-1 min-w-0">
                        <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-2 flex items-center flex-wrap gap-2">
                          {article.title}
                          {'featured' in article && article.featured && (
                            <span class="text-xs bg-primary-600 text-white px-2 py-0.5 rounded font-medium">10+ artykułów</span>
                          )}
                        </h3>
                        <p class="text-sm text-gray-600 leading-relaxed">
                          {article.description}
                        </p>
                        <div class="mt-3 flex items-center text-primary-600 font-medium text-sm">
                          Czytaj więcej
                          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>

              {/* Extra links for metodologia */}
              {category.id === 'badania' && (
                <div class="mt-6 bg-white rounded-xl p-6 border-2 border-dashed border-gray-200">
                  <p class="text-sm text-gray-500 mb-3 font-medium">Popularne artykuły z metodologii:</p>
                  <div class="flex flex-wrap gap-2">
                    {metodologiaHighlights.map((item) => (
                      <a 
                        href={item.href} 
                        class="text-sm bg-gray-100 hover:bg-primary-100 text-gray-700 hover:text-primary-700 px-4 py-2 rounded-full transition-colors"
                      >
                        {item.title} →
                      </a>
                    ))}
                    <a 
                      href="/poradniki/metodologia/" 
                      class="text-sm bg-primary-600 hover:bg-primary-700 text-white px-4 py-2 rounded-full transition-colors font-medium"
                    >
                      Zobacz wszystkie →
                    </a>
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Smart-Edu CTA -->
    <section class="py-16 bg-white">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <SmartEduCTA variant="full" />
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>