<ArticleLayout
  title="Jak napisać wstęp do pracy magisterskiej - porady + wzór"
  description="Kompletny poradnik jak napisać wstęp do pracy magisterskiej."
  readingTime="18 min"
  breadcrumbs={breadcrumbs}
