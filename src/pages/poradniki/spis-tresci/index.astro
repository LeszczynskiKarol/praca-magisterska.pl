<ArticleLayout
  title="Spis treści w pracy magisterskiej - jak napisać + wzór"
  description="Kompletny poradnik dotyczący tworzenia spisu treści do pracy magisterskiej"
  readingTime="18 min"
  breadcrumbs={breadcrumbs}
