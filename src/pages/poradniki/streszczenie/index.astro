const breadcrumbs = [
  { label: "Poradniki", href: "/poradniki/" },
  { label: "Streszczenie", href: "/poradniki/streszczenie/" },
];

const relatedLinks = [
  { label: "Wstęp do pracy magisterskiej", href: "/poradniki/wstep/" },
  { label: "Zakończenie pracy magisterskiej", href: "/poradniki/zakonczenie/" },
  { label: "Struktura pracy magisterskiej", href: "/poradniki/struktura/" },
