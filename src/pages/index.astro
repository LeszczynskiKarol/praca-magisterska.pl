---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SmartEduCTA from '../components/SmartEduCTA.astro';

// Poradniki
const poradniki = [
  { title: 'Jak napisać wstęp', description: 'Struktura wstępu, co powinien zawierać i jak go napisać krok po kroku.', href: '/poradniki/wstep/', icon: '📝' },
  { title: 'Jak napisać zakończenie', description: 'Struktura zakończenia, wnioski i podsumowanie wyników badań.', href: '/poradniki/zakonczenie/', icon: '✅' },
  { title: 'Bibliografia', description: 'Style cytowania (APA, Chicago, Harvard), tworzenie bibliografii.', href: '/poradniki/bibliografia/', icon: '📚' },
  { title: 'Metodologia badań', description: 'Metody, techniki, narzędzia badawcze i projektowanie badań.', href: '/poradniki/metodologia/', icon: '🔬', featured: true },
  { title: 'Konspekt pracy', description: 'Jak stworzyć plan pracy, który ułatwi pisanie.', href: '/poradniki/konspekt/', icon: '📋' },
  { title: 'Obrona pracy', description: 'Przygotowanie do obrony, typowe pytania komisji.', href: '/poradniki/obrona/', icon: '🎓' },
];

// Kierunki studiów
const kierunki = [
  { name: 'Pedagogika', href: '/tematy/pedagogika/', icon: '📚', count: '100+ tematów' },
  { name: 'Zarządzanie', href: '/tematy/zarzadzanie/', icon: '📊', count: '100+ tematów' },
  { name: 'Psychologia', href: '/tematy/psychologia/', icon: '🧠', count: '100+ tematów' },
  { name: 'Prawo', href: '/tematy/prawo/', icon: '⚖️', count: '100+ tematów' },
  { name: 'Marketing', href: '/tematy/marketing/', icon: '📈', count: '100+ tematów' },
  { name: 'Pielęgniarstwo', href: '/tematy/pielegniarstwo/', icon: '🏥', count: '100+ tematów' },
  { name: 'Logistyka', href: '/tematy/logistyka/', icon: '🚚', count: '100+ tematów' },
  { name: 'Administracja', href: '/tematy/administracja/', icon: '🏢', count: '100+ tematów' },
];

// Etapy pisania pracy
const etapyPisania = [
  { 
    step: 1, 
    title: 'Wybór tematu i promotora', 
    description: 'Znajdź temat, który Cię interesuje i skonsultuj go z promotorem. Dobry temat to połowa sukcesu.',
    duration: '2-4 tygodnie',
    href: '/poradniki/wybor-tematu/'
  },
  { 
    step: 2, 
    title: 'Przegląd literatury', 
    description: 'Zbierz źródła naukowe, książki i artykuły. Stwórz bazę wiedzy na temat swojego zagadnienia.',
    duration: '4-6 tygodni',
    href: '/poradniki/bibliografia/'
  },
  { 
    step: 3, 
    title: 'Konspekt i struktura', 
    description: 'Opracuj szczegółowy plan pracy z podziałem na rozdziały i podrozdziały.',
    duration: '1-2 tygodnie',
    href: '/poradniki/konspekt/'
  },
  { 
    step: 4, 
    title: 'Część teoretyczna', 
    description: 'Napisz rozdziały teoretyczne, definiując pojęcia i omawiając stan wiedzy.',
    duration: '6-8 tygodni',
    href: '/poradniki/rozdzial-teoretyczny/'
  },
  { 
    step: 5, 
    title: 'Badania własne', 
    description: 'Przeprowadź badania empiryczne - ankiety, wywiady lub analizy danych.',
    duration: '4-8 tygodni',
    href: '/poradniki/metodologia/'
  },
  { 
    step: 6, 
    title: 'Analiza i wnioski', 
    description: 'Opracuj wyniki badań, wyciągnij wnioski i napisz zakończenie.',
    duration: '3-4 tygodnie',
    href: '/poradniki/zakonczenie/'
  },
  { 
    step: 7, 
    title: 'Redakcja i formatowanie', 
    description: 'Dopracuj tekst, sprawdź cytowania, sformatuj pracę zgodnie z wymogami.',
    duration: '2-3 tygodnie',
    href: '/poradniki/formatowanie/'
  },
  { 
    step: 8, 
    title: 'Obrona pracy', 
    description: 'Przygotuj prezentację i odpowiedzi na potencjalne pytania komisji.',
    duration: '1-2 tygodnie',
    href: '/poradniki/obrona/'
  },
];

// Najczęstsze błędy
const najczestszeBłędy = [
  {
    title: 'Zbyt późne rozpoczęcie pisania',
    description: 'Pisanie pracy magisterskiej wymaga czasu. Rozpocznij minimum 6-9 miesięcy przed planowanym terminem obrony.',
    icon: '⏰'
  },
  {
    title: 'Brak regularnego kontaktu z promotorem',
    description: 'Konsultuj postępy co 2-3 tygodnie. Unikniesz przepisywania całych rozdziałów.',
    icon: '💬'
  },
  {
    title: 'Kopiowanie bez cytowania',
    description: 'Programy antyplagiatowe wykrywają nawet drobne zapożyczenia. Zawsze oznaczaj źródła.',
    icon: '📋'
  },
  {
    title: 'Zbyt ogólny temat',
    description: 'Zawęź temat do konkretnego problemu. "Marketing internetowy" to za mało - lepiej "Marketing w social mediach dla branży kosmetycznej".',
    icon: '🎯'
  },
  {
    title: 'Ignorowanie wymogów formalnych',
    description: 'Sprawdź wytyczne swojej uczelni dotyczące formatowania, marginesów i stylu cytowania.',
    icon: '📐'
  },
  {
    title: 'Słaba metodologia badań',
    description: 'Dobrze zaplanuj badania - określ próbę, narzędzia i metody analizy przed rozpoczęciem.',
    icon: '🔬'
  },
];

// FAQ
const faqItems = [
  {
    question: 'Ile stron powinna mieć praca magisterska?',
    answer: 'Standardowa praca magisterska liczy od 60 do 100 stron (bez załączników). Dokładne wymagania zależą od uczelni i kierunku studiów. Prace z kierunków humanistycznych są często dłuższe niż techniczne.'
  },
  {
    question: 'Ile czasu zajmuje napisanie pracy magisterskiej?',
    answer: 'Przy regularnej pracy potrzebujesz 6-9 miesięcy. Obejmuje to wybór tematu, przegląd literatury, przeprowadzenie badań, napisanie tekstu oraz korektę. Zacznij odpowiednio wcześnie, aby uniknąć stresu.'
  },
  {
    question: 'Czy mogę pisać pracę magisterską sam, bez pomocy?',
    answer: 'Tak, większość studentów pisze prace samodzielnie. Kluczowe jest regularne konsultowanie się z promotorem i korzystanie z poradników takich jak nasz. Ważne, żeby nie kopiować cudzych prac.'
  },
  {
    question: 'Jak wybrać temat pracy magisterskiej?',
    answer: 'Wybierz temat, który Cię interesuje i ma praktyczne zastosowanie. Sprawdź dostępność literatury i możliwość przeprowadzenia badań. Skonsultuj pomysł z promotorem - pomoże zawęzić zakres.'
  },
  {
    question: 'Co to jest plagiat i jak go uniknąć?',
    answer: 'Plagiat to przypisywanie sobie cudzych myśli lub tekstów. Unikniesz go poprzez prawidłowe cytowanie źródeł, parafrazowanie i używanie programu antyplagiatowego przed oddaniem pracy.'
  },
  {
    question: 'Jak wygląda obrona pracy magisterskiej?',
    answer: 'Obrona trwa 20-40 minut. Prezentujesz główne tezy pracy (10-15 min), następnie odpowiadasz na pytania komisji i recenzenta. Przygotuj się na pytania o metodologię i wnioski.'
  },
  {
    question: 'Ile źródeł powinna zawierać bibliografia?',
    answer: 'Minimum 30-50 pozycji dla pracy magisterskiej. Staraj się korzystać z aktualnych źródeł (nie starszych niż 10 lat) oraz publikacji naukowych, a nie tylko stron internetowych.'
  },
  {
    question: 'Czy AI może pomóc w pisaniu pracy magisterskiej?',
    answer: 'Narzędzia AI mogą pomóc w generowaniu pomysłów, strukturyzowaniu tekstu czy poprawie stylistyki. Pamiętaj jednak, że ostateczna praca musi być Twoim dziełem. Sprawdź politykę swojej uczelni dotyczącą AI.'
  },
];

// Schema.org
const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Praca-Magisterska.pl",
  "description": "Kompletny poradnik pisania prac magisterskich. Tematy, metodologia, struktura i profesjonalne wskazówki dla studentów.",
  "url": "https://www.praca-magisterska.pl",
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout
  title="Praca magisterska - poradniki, tematy, metodologia | Praca-Magisterska.pl"
  description="Praca magisterska od A do Z: jak napisać wstęp, metodologię i zakończenie, 2500+ tematów z 25 kierunków, struktura, bibliografia. Kompletny darmowy poradnik 2026."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="pt-28 pb-20 bg-gradient-to-br from-primary-50 via-white to-accent/10 overflow-hidden relative">
      <!-- Decorative elements -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
      </div>
      
      <div class="container-custom relative">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 px-4 py-2 rounded-full text-sm font-medium mb-6 animate-fade-in">
            <span class="animate-pulse">🎓</span>
            <span>Kompletny poradnik dla studentów</span>
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 mb-6 leading-tight animate-slide-up">
            Praca magisterska
            <span class="text-gradient"> od tematu do obrony</span>
          </h1>
          
          <p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-2xl mx-auto animate-slide-up" style="animation-delay: 0.1s;">
            Profesjonalne poradniki, tematy prac z 20+ kierunków studiów, metodologia badań i sprawdzone wskazówki. Wszystko, czego potrzebujesz, aby napisać doskonałą pracę magisterską.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s;">
            <a href="/sklep/praca-magisterska-ebook/" class="btn-primary w-full sm:w-auto">
              📗 Ebook: jak napisać pracę magisterską
              <span class="ml-2 bg-white/25 text-white text-sm font-bold px-2 py-0.5 rounded">39 zł</span>
            </a>
            <a href="https://smart-edu.ai" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full sm:w-auto">
              Napisz pracę z AI →
            </a>
          </div>
          <p class="mt-5 text-sm text-gray-500 animate-slide-up" style="animation-delay: 0.25s;">
            albo przeglądaj <a href="/poradniki/" class="text-primary-600 font-medium hover:underline">darmowe poradniki</a>
            i <a href="/tematy/" class="text-primary-600 font-medium hover:underline">tematy prac</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-8 bg-white border-b border-gray-100">
      <div class="container-custom">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
          <div class="animate-on-scroll">
            <div class="text-3xl font-bold text-primary-600">20+</div>
            <div class="text-gray-600 text-sm">Kierunków studiów</div>
          </div>
          <div class="animate-on-scroll" style="transition-delay: 0.1s;">
            <div class="text-3xl font-bold text-primary-600">2000+</div>
            <div class="text-gray-600 text-sm">Tematów prac</div>
          </div>
          <div class="animate-on-scroll" style="transition-delay: 0.2s;">
            <div class="text-3xl font-bold text-primary-600">30+</div>
            <div class="text-gray-600 text-sm">Poradników</div>
          </div>
          <div class="animate-on-scroll" style="transition-delay: 0.3s;">
            <div class="text-3xl font-bold text-primary-600">100%</div>
            <div class="text-gray-600 text-sm">Za darmo</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Smart-Edu CTA -->
    <section class="py-12 bg-white">
      <div class="container-custom">
        <div class="max-w-5xl mx-auto">
          <SmartEduCTA variant="full" />
        </div>
      </div>
    </section>

    <!-- NOWA SEKCJA: Proces pisania krok po kroku -->
    <section class="py-16 bg-gradient-to-b from-gray-50 to-white">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="badge badge-primary mb-4">📖 Poradnik krok po kroku</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Pisanie pracy magisterskiej - 8 etapów do sukcesu
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Sprawdzony proces, który pomoże Ci napisać pracę magisterską bez stresu i w terminie
          </p>
        </div>

        <div class="max-w-4xl mx-auto">
          <div class="relative">
            <!-- Linia pionowa łącząca kroki -->
            <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary-400 via-primary-500 to-accent hidden md:block"></div>
            
            <div class="space-y-6">
              {etapyPisania.map((etap, index) => (
                <a 
                  href={etap.href}
                  class="block relative pl-0 md:pl-20 animate-on-scroll group"
                  style={`transition-delay: ${index * 0.05}s;`}
                >
                  <!-- Numer kroku -->
                  <div class="hidden md:flex absolute left-0 w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 text-white rounded-2xl items-center justify-center font-bold text-xl shadow-lg group-hover:scale-110 transition-transform z-10">
                    {etap.step}
                  </div>
                  
                  <!-- Karta z treścią -->
                  <div class="card card-hover">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                      <div class="flex md:hidden w-12 h-12 bg-primary-600 text-white rounded-xl items-center justify-center font-bold text-lg flex-shrink-0">
                        {etap.step}
                      </div>
                      <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                          <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors text-lg">
                            {etap.title}
                          </h3>
                          <span class="text-xs bg-primary-100 text-primary-700 px-2 py-1 rounded-full font-medium">
                            {etap.duration}
                          </span>
                        </div>
                        <p class="text-gray-600">
                          {etap.description}
                        </p>
                      </div>
                      <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-600 group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="text-center mt-10">
          <a href="/poradniki/jak-napisac-prace-magisterska/" class="btn-primary">
            Rozpocznij od podstaw
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Poradniki Section -->
    <section class="py-16 bg-gray-50">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="badge badge-primary mb-4">📖 Poradniki</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Jak napisać pracę magisterską - szczegółowe poradniki
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Kompletne przewodniki po każdym elemencie pracy dyplomowej
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {poradniki.map((item, index) => (
            <a 
              href={item.href}
              class={`card card-hover group animate-on-scroll ${item.featured ? 'ring-2 ring-primary-400 bg-primary-50/50' : ''}`}
              style={`transition-delay: ${index * 0.05}s;`}
            >
              <div class="flex items-start gap-4">
                <span class="text-3xl flex-shrink-0">{item.icon}</span>
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-2 flex items-center gap-2">
                    {item.title}
                    {item.featured && (
                      <span class="text-xs bg-primary-600 text-white px-2 py-0.5 rounded font-medium">Popularne</span>
                    )}
                  </h3>
                  <p class="text-sm text-gray-600 leading-relaxed">
                    {item.description}
                  </p>
                  <div class="mt-3 flex items-center text-primary-600 font-medium text-sm">
                    Czytaj więcej
                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/poradniki/" class="btn-secondary">
            Zobacz wszystkie poradniki →
          </a>
        </div>
      </div>
    </section>

    <!-- NOWA SEKCJA: Najczęstsze błędy -->
    <section class="py-16 bg-white">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="badge bg-red-100 text-red-700 mb-4">⚠️ Uwaga</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Najczęstsze błędy przy pisaniu pracy magisterskiej
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Unikaj tych pułapek, które opóźniają ukończenie pracy i obniżają jej jakość
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {najczestszeBłędy.map((błąd, index) => (
            <div 
              class="card border-l-4 border-l-red-400 hover:border-l-red-500 animate-on-scroll"
              style={`transition-delay: ${index * 0.05}s;`}
            >
              <div class="flex items-start gap-4">
                <span class="text-2xl flex-shrink-0">{błąd.icon}</span>
                <div>
                  <h3 class="font-bold text-gray-900 mb-2">{błąd.title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed">{błąd.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 max-w-3xl mx-auto">
          <div class="bg-green-50 border border-green-200 rounded-2xl p-6 text-center">
            <span class="text-3xl mb-3 block">💡</span>
            <h3 class="font-bold text-green-800 mb-2">Dobra wiadomość</h3>
            <p class="text-green-700">
              Dzięki naszym poradnikom i szablonom unikniesz większości typowych błędów. 
              Sprawdź nasze materiały i pisz pracę pewnie i bez stresu.
            </p>
            <a href="/poradniki/" class="inline-flex items-center text-green-700 font-semibold mt-3 hover:text-green-800">
              Przejdź do poradników
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Tematy prac Section -->
    <section class="py-16 bg-gray-50">
      <div class="container-custom">
        <div class="text-center mb-12">
          <span class="badge badge-accent mb-4">🎯 Tematy prac</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Tematy prac magisterskich z Twojego kierunku
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Wybierz kierunek studiów i znajdź inspirujące tematy oraz wskazówki
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
          {kierunki.map((item, index) => (
            <a 
              href={item.href}
              class="card card-hover text-center group animate-on-scroll"
              style={`transition-delay: ${index * 0.05}s;`}
            >
              <span class="text-4xl mb-3 block group-hover:scale-110 transition-transform">{item.icon}</span>
              <h3 class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-1">
                {item.name}
              </h3>
              <p class="text-xs text-gray-500">{item.count}</p>
            </a>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/tematy/" class="btn-primary">
            Zobacz wszystkie kierunki
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
