---
// Reużywalne pudełko „do pobrania" (PDF + Word) dla poradników i stron tematów.
interface FileLink {
  href: string;
  label: string;
  primary?: boolean;
}
interface Props {
  title?: string;
  description?: string;
  files: FileLink[];
}
const {
  title = "📄 Pobierz wzór – PDF i Word",
  description,
  files,
} = Astro.props;
---

<div class="download-box">
  <p class="download-title">{title}</p>
  {description && <p class="download-desc">{description}</p>}
  <div class="download-actions">
    {
      files.map((f) => (
        <a
          class={`download-btn${f.primary === false ? " download-btn-alt" : ""}`}
          href={f.href}
          download
        >
          {f.label}
        </a>
      ))
    }
  </div>
</div>

<style>
  .download-box {
    border: 1px solid #c7d2fe;
    border-left: 4px solid #4f46e5;
    border-radius: 0.5rem;
    background: #f5f7ff;
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }
  .download-title {
    font-weight: 700;
    color: #3730a3;
    margin-top: 0;
  }
  .download-desc {
    margin-bottom: 0.75rem;
  }
  .download-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .download-btn {
    display: inline-block;
    background: #4f46e5;
    color: #fff;
    font-weight: 600;
    padding: 0.6rem 1.4rem;
    border-radius: 0.5rem;
    text-decoration: none;
  }
  .download-btn:hover {
    background: #4338ca;
  }
  .download-btn-alt {
    background: #fff;
    color: #4f46e5;
    border: 2px solid #4f46e5;
    padding: calc(0.6rem - 2px) calc(1.4rem - 2px);
  }
  .download-btn-alt:hover {
    background: #eef2ff;
  }
</style>
